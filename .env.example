# OpenArchive local development environment example

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
OA_RELATIONAL_STORE=sqlite
OA_VECTOR_STORE=qdrant
OA_OBJECT_STORE=local_fs
OA_SQLITE_PATH=${HOME}/.open_archive/open_archive.db
OA_OBJECT_STORE_ROOT=${HOME}/.open_archive/objects
OA_QDRANT_URL=http://127.0.0.1:6333
OA_QDRANT_COLLECTION=oa_derived_object_embeddings
OA_QDRANT_MANAGED=true
OA_QDRANT_VERSION=1.17.1

OA_HTTP_BIND=0.0.0.0:3000
OA_HTTP_REQUEST_WORKERS=2
OA_ENRICHMENT_WORKERS=1
OA_ENRICHMENT_POLL_INTERVAL_MS=2000
RUST_LOG=info

# Direct mode worker settings
OA_DIRECT_EXTRACT_WORKERS=1
OA_DIRECT_RECONCILE_WORKERS=1
OA_DIRECT_EMBEDDING_WORKERS=1

# Batch mode worker settings
OA_BATCH_EXTRACT_WORKERS=1
OA_BATCH_EXTRACT_BATCH_SIZE=1
OA_BATCH_EXTRACT_MAX_CONCURRENT=60
OA_BATCH_RECONCILE_WORKERS=1
OA_BATCH_RECONCILE_BATCH_SIZE=1
OA_BATCH_RECONCILE_MAX_CONCURRENT=60
OA_BATCH_EMBEDDING_WORKERS=4

# -----------------------------------------------------------------------------
# Default local smoke-test path
# -----------------------------------------------------------------------------
# These defaults are intended to boot local runtime with no external model
# credentials. They validate import, storage, enrichment orchestration, and
# MCP wiring, but not real enrichment quality.
OA_MODEL_PROVIDER=stub
OA_INFERENCE_MODE=direct
OA_EMBEDDING_PROVIDER=disabled

# -----------------------------------------------------------------------------
# Common model selection
# The application decides where to use the heavy vs fast model internally.
# Embedding dimensions become part of vector-store setup on first run.
# Changing them later requires collection recreation and re-embedding.
# The managed Qdrant sidecar first prefers a bundled binary next to the
# OpenArchive executable, then falls back to downloading the matching release
# asset into OA_QDRANT_INSTALL_ROOT.
# -----------------------------------------------------------------------------
OA_HEAVY_MODEL=gemini-3-flash-preview
OA_FAST_MODEL=gemini-2.5-flash-lite
OA_EMBEDDING_MODEL=gemini-embedding-001
OA_EMBEDDING_DIMENSIONS=3072
OA_QDRANT_INSTALL_ROOT=${HOME}/.open_archive/qdrant
OA_QDRANT_STORAGE_PATH=${HOME}/.open_archive/qdrant/storage
OA_QDRANT_LOG_PATH=${HOME}/.open_archive/qdrant/qdrant.log
OA_QDRANT_STARTUP_TIMEOUT_MS=30000

# Optional override when shipping a colocated Qdrant binary.
# OA_QDRANT_BINARY_PATH=/path/to/qdrant

# -----------------------------------------------------------------------------
# Optional Postgres
# -----------------------------------------------------------------------------
OA_POSTGRES_DB=openarchive
OA_POSTGRES_USER=openarchive
OA_POSTGRES_PASSWORD=openarchive
OA_POSTGRES_URL=postgres://openarchive:openarchive@127.0.0.1:5432/openarchive

# -----------------------------------------------------------------------------
# Oracle
# -----------------------------------------------------------------------------
OA_ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
OA_ORACLE_USERNAME=system
OA_ORACLE_PASSWORD=change-me
OA_ORACLE_CALL_TIMEOUT_MS=30000
OA_DB_POOL_MIN=1
OA_DB_POOL_MAX=8
OA_DB_POOL_INCREMENT=1
OA_DB_POOL_STMT_CACHE_SIZE=50
OA_DB_POOL_GET_TIMEOUT_MS=30000
OA_DB_POOL_PING_INTERVAL_MS=60000
OA_ORACLE_CONTAINER_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Object storage (S3-compatible, optional)
# -----------------------------------------------------------------------------
OA_S3_ENDPOINT=https://example.compat.objectstorage.us-phoenix-1.oci.customer-oci.com
OA_S3_REGION=us-phoenix-1
OA_S3_BUCKET=openarchive
OA_S3_URL_STYLE=path
OA_S3_KEY_PREFIX=openarchive
OA_S3_ACCESS_KEY_ID=change-me
OA_S3_SECRET_ACCESS_KEY=change-me

# -----------------------------------------------------------------------------
# Native OpenAI
# -----------------------------------------------------------------------------
OA_OPENAI_API_KEY=change-me
OA_OPENAI_BASE_URL=https://api.openai.com/v1
OA_OPENAI_MAX_OUTPUT_TOKENS=4000
OA_OPENAI_REASONING_EFFORT=auto

# -----------------------------------------------------------------------------
# Native Gemini
# -----------------------------------------------------------------------------
OA_GEMINI_API_KEY=change-me
OA_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OA_GEMINI_MAX_OUTPUT_TOKENS=4000
OA_GEMINI_BATCH_ENABLED=true
OA_GEMINI_BATCH_MAX_JOBS=16
OA_GEMINI_BATCH_MAX_BYTES=1500000
OA_GEMINI_BATCH_POLL_INTERVAL_MS=5000

# -----------------------------------------------------------------------------
# Native Anthropic / Claude
# -----------------------------------------------------------------------------
OA_ANTHROPIC_API_KEY=change-me
OA_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
OA_ANTHROPIC_MAX_OUTPUT_TOKENS=4000

# -----------------------------------------------------------------------------
# Native Grok
# -----------------------------------------------------------------------------
OA_GROK_API_KEY=change-me
OA_GROK_BASE_URL=https://api.x.ai/v1
OA_GROK_MAX_OUTPUT_TOKENS=4000

# -----------------------------------------------------------------------------
# OCI Generative AI
# Uses the local OCI CLI for auth and request signing.
# Current implementation is direct-only; set OA_INFERENCE_MODE=direct.
# -----------------------------------------------------------------------------
OA_OCI_REGION=us-chicago-1
OA_OCI_COMPARTMENT_ID=ocid1.compartment.oc1..change-me
OA_OCI_CLI_PATH=oci
OA_OCI_PROFILE=
OA_OCI_MAX_OUTPUT_TOKENS=4000
OA_OCI_REPAIR_MAX_OUTPUT_TOKENS=4096

# -----------------------------------------------------------------------------
# Integration test overrides
# -----------------------------------------------------------------------------
OA_POSTGRES_INTEGRATION_TESTS=
OA_ORACLE_INTEGRATION_TESTS=
OA_ALLOW_SCHEMA_RESET=
OA_TEST_POSTGRES_URL=postgres://openarchive:openarchive@127.0.0.1:5432/openarchive_test
OA_TEST_ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
OA_TEST_ORACLE_USERNAME=system
OA_TEST_ORACLE_PASSWORD=change-me
OA_TEST_SCHEMA_USERNAME=system
