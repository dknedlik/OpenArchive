# OpenArchive local defaults
#
# Provider selection:
# - OA_RELATIONAL_STORE=postgres for the default local Compose path
# - OA_RELATIONAL_STORE=oracle to run the Oracle provider instead
# - OA_OBJECT_STORE=local_fs for local Docker-volume storage
# - OA_OBJECT_STORE=s3 for a real remote S3-compatible bucket

# Default local Compose stack
OA_RELATIONAL_STORE=postgres
OA_OBJECT_STORE=local_fs

# Local filesystem object store
OA_OBJECT_STORE_ROOT=/var/lib/openarchive/objects

# Remote S3-compatible object store
# Set OA_OBJECT_STORE=s3 to activate these settings.
# OCI Object Storage example:
# OA_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oci.customer-oci.com
# OA_S3_REGION=us-phoenix-1
# OA_S3_BUCKET=ce-assets
# OA_S3_URL_STYLE=path
OA_S3_ENDPOINT=
OA_S3_REGION=
OA_S3_BUCKET=
OA_S3_ACCESS_KEY_ID=
OA_S3_SECRET_ACCESS_KEY=
OA_S3_KEY_PREFIX=
OA_S3_URL_STYLE=path

# HTTP and worker runtime
OA_HTTP_BIND=0.0.0.0:3000
OA_HTTP_REQUEST_WORKERS=2
OA_ENRICHMENT_WORKERS=1
OA_ENRICHMENT_POLL_INTERVAL_MS=500
RUST_LOG=info

# Postgres relational provider
# Set OA_RELATIONAL_STORE=postgres to use these settings.
OA_POSTGRES_DB=openarchive
OA_POSTGRES_USER=openarchive
OA_POSTGRES_PASSWORD=openarchive
OA_POSTGRES_URL=postgres://openarchive:openarchive@postgres:5432/openarchive

# Oracle relational provider
# Set OA_RELATIONAL_STORE=oracle to use these settings.
# `OA_ORACLE_CONNECT_STRING` is for host-side tools and tests.
# `OA_DOCKER_ORACLE_CONNECT_STRING` is what the app container should use.
OA_ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
OA_DOCKER_ORACLE_CONNECT_STRING=oracle:1521/FREEPDB1
OA_ORACLE_USERNAME=system
OA_ORACLE_PASSWORD=openarchive
OA_ORACLE_CALL_TIMEOUT_MS=30000
OA_DB_POOL_MIN=1
OA_DB_POOL_MAX=8
OA_DB_POOL_INCREMENT=1
OA_DB_POOL_STMT_CACHE_SIZE=50
OA_DB_POOL_GET_TIMEOUT_MS=30000
OA_DB_POOL_PING_INTERVAL_MS=60000

# Inference providers
# OA_INFERENCE_PROVIDER=stub       -- default, no model calls
# OA_INFERENCE_PROVIDER=openrouter -- OpenRouter for standard/quality tiers
# OA_INFERENCE_PROVIDER=ollama     -- local Ollama (requires ollama profile)
OA_INFERENCE_PROVIDER=stub
OA_OPENROUTER_API_KEY=
OA_OPENROUTER_STANDARD_MODEL=meta-llama/llama-3.1-70b-instruct
OA_OPENROUTER_QUALITY_MODEL=anthropic/claude-sonnet-4-5
OA_OLLAMA_URL=http://ollama:11434
OA_ANTHROPIC_API_KEY=

# Integration test overrides
OA_POSTGRES_INTEGRATION_TESTS=
OA_ORACLE_INTEGRATION_TESTS=
OA_ALLOW_SCHEMA_RESET=
OA_TEST_ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
OA_TEST_ORACLE_USERNAME=system
OA_TEST_ORACLE_PASSWORD=openarchive
OA_TEST_SCHEMA_USERNAME=
OA_TEST_POSTGRES_URL=postgres://openarchive:openarchive@127.0.0.1:5432/openarchive_test

# Local Oracle container password (gvenzl/oracle-free:23-faststart)
# Used by `make up-oracle-db`. Maps to ORACLE_PASSWORD in the container.
OA_ORACLE_CONTAINER_PASSWORD=openarchive
