# OpenArchive local development environment example

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
OA_RELATIONAL_STORE=postgres
OA_OBJECT_STORE=s3
OA_OBJECT_STORE_ROOT=/var/lib/openarchive/objects

OA_HTTP_BIND=0.0.0.0:3000
OA_HTTP_REQUEST_WORKERS=2
OA_ENRICHMENT_WORKERS=1
OA_ENRICHMENT_POLL_INTERVAL_MS=2000
OA_PREPROCESS_WORKERS=1
OA_EXTRACT_WORKERS=1
OA_RECONCILE_WORKERS=1
OA_RETRIEVE_CONTEXT_WORKERS=2
RUST_LOG=info
OA_PREPROCESS_BATCH_SIZE=1
OA_PREPROCESS_MAX_CONCURRENT=60
OA_EXTRACT_BATCH_SIZE=1
OA_EXTRACT_MAX_CONCURRENT=60
OA_RECONCILE_BATCH_SIZE=1
OA_RECONCILE_MAX_CONCURRENT=60
OA_RATE_LIMIT_RPM=4000

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
OA_POSTGRES_DB=openarchive
OA_POSTGRES_USER=openarchive
OA_POSTGRES_PASSWORD=openarchive
OA_POSTGRES_URL=postgres://openarchive:openarchive@postgres:5432/openarchive

# -----------------------------------------------------------------------------
# Oracle
# -----------------------------------------------------------------------------
OA_ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
OA_ORACLE_USERNAME=system
OA_ORACLE_PASSWORD=change-me
OA_ORACLE_CALL_TIMEOUT_MS=30000
OA_DB_POOL_MIN=1
OA_DB_POOL_MAX=8
OA_DB_POOL_INCREMENT=1
OA_DB_POOL_STMT_CACHE_SIZE=50
OA_DB_POOL_GET_TIMEOUT_MS=30000
OA_DB_POOL_PING_INTERVAL_MS=60000
OA_ORACLE_CONTAINER_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Object storage (OCI-compatible S3)
# -----------------------------------------------------------------------------
OA_S3_ENDPOINT=https://example.compat.objectstorage.us-phoenix-1.oci.customer-oci.com
OA_S3_REGION=us-phoenix-1
OA_S3_BUCKET=openarchive
OA_S3_URL_STYLE=path
OA_S3_KEY_PREFIX=openarchive
OA_S3_ACCESS_KEY_ID=change-me
OA_S3_SECRET_ACCESS_KEY=change-me

# -----------------------------------------------------------------------------
# Inference provider selection
# -----------------------------------------------------------------------------
OA_INFERENCE_PROVIDER=gemini
OA_INFERENCE_MODE=direct

# -----------------------------------------------------------------------------
# Native OpenAI
# -----------------------------------------------------------------------------
OA_OPENAI_API_KEY=change-me
OA_OPENAI_BASE_URL=https://api.openai.com/v1
OA_OPENAI_MAX_OUTPUT_TOKENS=4000
OA_OPENAI_STANDARD_MODEL=gpt-5-mini
OA_OPENAI_QUALITY_MODEL=gpt-5.4
OA_OPENAI_REASONING_EFFORT=low

# -----------------------------------------------------------------------------
# Native Gemini
# -----------------------------------------------------------------------------
OA_GEMINI_API_KEY=change-me
OA_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OA_GEMINI_MAX_OUTPUT_TOKENS=4000
OA_GEMINI_STANDARD_MODEL=gemini-3.1-flash-lite-preview
OA_GEMINI_QUALITY_MODEL=gemini-3.1-pro-preview
OA_GEMINI_BATCH_ENABLED=true
OA_GEMINI_BATCH_MAX_JOBS=16
OA_GEMINI_BATCH_MAX_BYTES=1500000
OA_GEMINI_BATCH_POLL_INTERVAL_MS=5000

# -----------------------------------------------------------------------------
# Native Anthropic / Claude
# -----------------------------------------------------------------------------
OA_ANTHROPIC_API_KEY=change-me
OA_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
OA_ANTHROPIC_MAX_OUTPUT_TOKENS=4000
OA_ANTHROPIC_STANDARD_MODEL=claude-haiku-4-5
OA_ANTHROPIC_QUALITY_MODEL=

# -----------------------------------------------------------------------------
# Native Grok
# -----------------------------------------------------------------------------
OA_GROK_API_KEY=change-me
OA_GROK_BASE_URL=https://api.x.ai/v1
OA_GROK_MAX_OUTPUT_TOKENS=4000
OA_GROK_STANDARD_MODEL=grok-4-1-fast-non-reasoning
OA_GROK_QUALITY_MODEL=

# -----------------------------------------------------------------------------
# Integration test overrides
# -----------------------------------------------------------------------------
OA_POSTGRES_INTEGRATION_TESTS=
OA_ORACLE_INTEGRATION_TESTS=
OA_ALLOW_SCHEMA_RESET=
OA_TEST_POSTGRES_URL=postgres://openarchive:openarchive@127.0.0.1:5432/openarchive_test
OA_TEST_ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
OA_TEST_ORACLE_USERNAME=system
OA_TEST_ORACLE_PASSWORD=change-me
OA_TEST_SCHEMA_USERNAME=system
